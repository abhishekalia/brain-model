# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Your Modal TRIBE v2 endpoint URL — get this after running:
#   modal deploy tribe_worker/modal_app.py
# It will print something like:
#   https://your-username--brain-trigger-tribe-worker-analyze-video-endpoint.modal.run
TRIBE_ENDPOINT_URL=https://your-username--brain-trigger-tribe-worker-...modal.run

# ── Optional ──────────────────────────────────────────────────────────────────

# Set a secret key to protect your Modal endpoint from public use.
# If set, add the same value as a Modal secret named "tribe-api-key".
TRIBE_API_KEY=

# Airtable — only needed if you want the waitlist feature
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Brain-Trigger
